#include <WiFi.h>

const char* ssid     = "scoobydoo gateway";
const char* password = "scoobydoo";

int ledPin = 8; 

void setup() {
  // Set up the LED
  ledcAttach(ledPin, 5000, 8);
  ledcWrite(ledPin, 0);

  // --- THE FIX: FORCE A PHYSICAL RADIO RESET ---
  esp_restart(); // This reboots the Wi-Fi radio hardware
  delay(1000);

  // Start the connection
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  // Wait for connection
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    attempts++;
    // Fast blink while trying
    ledcWrite(ledPin, 255);
    delay(100);
    ledcWrite(ledPin, 0);
    delay(400);
    
    if (attempts > 60) { 
      // If it fails after 30 seconds, just turn the light red (solid) and freeze
      ledcWrite(ledPin, 255);
      while(1); 
    }
  }

  // SUCCESS: Solid Blue!
  ledcWrite(ledPin, 255); 
}

void loop() {
  // Keep the light solid blue forever
  ledcWrite(ledPin, 255);
}