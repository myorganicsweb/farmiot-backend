// ==========================================
// FARMIOT ESP32-C3: UNIVERSAL FAILOVER CLIENT
// ==========================================

#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <WebSocketsClient.h>
#include <ArduinoOTA.h>
#include <HTTPUpdate.h>  

// --- WIFI CREDENTIALS ---
const char* ssid = "scoobydoo gateway";
const char* pwd  = "scoobydoo";

// --- YOUR RENDER BACKEND URL ---
const char* wsServer = "farmiot-backend.onrender.com"; 
const char* deviceId = "esp32_01";

// --- ESP32-C3 PIN ---
int ledPin = 8;

WebSocketsClient webSocket;

void setup() {
  // 1. SET UP LED
  ledcAttach(ledPin, 5000, 8);
  ledcWrite(ledPin, 0); 

  // 2. CONNECT TO WIFI
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, pwd);
  
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    attempts++;
    ledcWrite(ledPin, 255);
    delay(100);
    ledcWrite(ledPin, 0);
    delay(400);
    
    if (attempts > 40) {
      while(1) { ledcWrite(ledPin, 255); delay(100); ledcWrite(ledPin, 0); delay(100); }
    }
  }

  // --- UNIVERSAL DNS FAILOVER (FIXED SYNTAX) ---
  // 1. Try Google DNS (8.8.8.8)
  IPAddress googleDNS(8, 8, 8, 8);
  WiFi.setDNS(googleDNS);
  delay(500);
  
  // 2. If Google fails, fallback to Cloudflare DNS (1.1.1.1)
  if (WiFi.status() != WL_CONNECTED) {
    IPAddress cloudflareDNS(1, 1, 1, 1);
    WiFi.setDNS(cloudflareDNS);
    delay(500);
  }

  // 3. CONNECT TO REMOTE OTA SERVER
  webSocket.begin(wsServer, 443, "/" + String(deviceId));
  webSocket.onEvent(webSocketEvent);
  webSocket.enableHeartbeat(30000, 5000, 2);

  // 4. LED SOLID BLUE = READY
  ledcWrite(ledPin, 255); 
}

void loop() {
  webSocket.loop();
  delay(10);
}

void webSocketEvent(WStype_t type, uint8_t * payload, size_t length) {
  switch(type) {
    case WStype_DISCONNECTED:
      ledcWrite(ledPin, 0);
      break;
    case WStype_CONNECTED:
      ledcWrite(ledPin, 255);
      break;
    case WStype_TEXT:
      String command = String((char*)payload);
      if (command.indexOf("ota_update") > 0) {
        performOTAUpdate(command);
      }
      break;
  }
}

void performOTAUpdate(String command) {
  int start = command.indexOf("url\":\"") + 6;
  int end = command.indexOf("\"", start);
  String firmwareUrl = command.substring(start, end);
  
  for(int i=0; i<3; i++) { ledcWrite(ledPin, 255); delay(100); ledcWrite(ledPin, 0); delay(100); }

  WiFiClientSecure client;
  client.setInsecure(); 

  t_httpUpdate_return ret = httpUpdate.update(client, firmwareUrl);
  
  switch(ret) {
    case HTTP_UPDATE_FAILED:
      while(1) { ledcWrite(ledPin, 255); delay(50); ledcWrite(ledPin, 0); delay(50); }
      break;
    case HTTP_UPDATE_OK:
      ledcWrite(ledPin, 255); delay(1000);
      ESP.restart();
      break;
  }
}