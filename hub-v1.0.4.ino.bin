// ==========================================
// FARMIOT FINAL: VERSION REPORTING VIA POLLING
// ==========================================

#include <WiFi.h>
#include <HTTPClient.h>
#include <Preferences.h>
#include <ArduinoJson.h>

Preferences preferences;
int onboardLed = 8;
int externalLed = 7;

const char* wsServer = "farm-iot.onrender.com";
const char* FIRMWARE_VERSION = "v1.0.2";

String lastFirmwareUrl = "";
unsigned long lastPollTime = 0;
const unsigned long POLL_INTERVAL = 500;

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== FarmIOT Hub Starting ===");

  pinMode(onboardLed, OUTPUT);
  pinMode(externalLed, OUTPUT);
  digitalWrite(onboardLed, LOW);
  digitalWrite(externalLed, LOW);

  preferences.begin("wifi", false);
  String savedSSID = preferences.getString("ssid", "scoobydoo");
  String savedPass = preferences.getString("password", "scoobydoo");
  preferences.end();

  WiFi.mode(WIFI_STA);
  WiFi.begin(savedSSID.c_str(), savedPass.c_str());

  Serial.print("Connecting to Wi-Fi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\n✅ Wi-Fi Connected!");
  Serial.print("📡 IP Address: ");
  Serial.println(WiFi.localIP());
  digitalWrite(onboardLed, HIGH);
}

void loop() {
  unsigned long currentTime = millis();
  if (currentTime - lastPollTime >= POLL_INTERVAL) {
    lastPollTime = currentTime;
    
    if (WiFi.status() == WL_CONNECTED) {
      HTTPClient http;
      
      WiFi.setTxPower(WIFI_POWER_19_5dBm);
      
      // --- POLL THE BACKEND FOR LED STATE AND FIRMWARE ---
      // We will send the version as a query parameter
      String url = "https://" + String(wsServer) + "/api/poll?version=" + String(FIRMWARE_VERSION);
      http.begin(url);
      int httpCode = http.GET();

      if (httpCode > 0) {
        String payload = http.getString();
        Serial.println("📡 Server says: " + payload);

        DynamicJsonDocument doc(256);
        deserializeJson(doc, payload);
        String state = doc["state"];
        String firmwareUrl = doc["firmwareUrl"] | "";
        bool forceUpdate = doc["force_update"] | false;

        if (state == "on") {
          digitalWrite(externalLed, HIGH);
          Serial.println("💡 LED turned ON");
        } else if (state == "off") {
          digitalWrite(externalLed, LOW);
          Serial.println("💡 LED turned OFF");
        }

        if (forceUpdate || (firmwareUrl.length() > 0 && firmwareUrl != lastFirmwareUrl)) {
          Serial.println("⬇️ New firmware available: " + firmwareUrl);
          lastFirmwareUrl = firmwareUrl;
          performOTAUpdate(firmwareUrl);
        }
      } else {
        Serial.println("❌ HTTP request failed");
      }
      http.end();
    }
  }
}

void performOTAUpdate(String firmwareUrl) {
  Serial.println("⬇️ Downloading firmware from: " + firmwareUrl);
  
  for(int i=0; i<3; i++) { 
    digitalWrite(onboardLed, HIGH);
    delay(100);
    digitalWrite(onboardLed, LOW);
    delay(100);
  }

  HTTPClient http;
  http.begin(firmwareUrl);
  int httpCode = http.GET();

  if (httpCode == 200) {
    Serial.println("✅ Firmware downloaded successfully.");
    Serial.println("🔁 Rebooting to apply update...");
    delay(1000);
    ESP.restart();
  } else {
    Serial.println("❌ Firmware download failed. Error: " + String(httpCode));
  }
  http.end();
}